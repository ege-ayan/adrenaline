# Adrenaline does not require a .env file for normal use.
#
# To run `adrenaline` from anywhere after building from source:
#
#   make install
#   export PATH="$HOME/.cargo/bin:$PATH"   # add to ~/.zshrc if missing
#
# Or, for local dev in this repo only:
#
#   make build
#   source scripts/env.sh
#
# With direnv installed, `.envrc` adds ./target/release to PATH automatically.
